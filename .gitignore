# chat2hamnosys prompts runner artifacts
# add these entries to your repo root .gitignore

# local prompt scratch dirs (kept out of the repo root); the versioned
# chat2hamnosys prompt library under backend/chat2hamnosys/prompts/ is
# committed — un-ignore it explicitly and ignore only its run artifacts.
prompts/
!backend/chat2hamnosys/prompts/
!docs/contrib-fix/prompts/
!docs/translator-fix/prompts/
backend/chat2hamnosys/prompts/eval_results/

# runner scripts
run_chat2hamnosys.sh
run_*.sh

# run logs
logs/
*.log

# claude-code local state
.claude/
.anthropic/

# chat2hamnosys runtime SQLite stores (created on first use)
data/chat2hamnosys/
data/authored_signs.sqlite3*

# env + secrets (should already be gitignored, here for safety)
.env
.env.local
.env.*.local
*.key
*.pem

# OS/editor noise
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
__pycache__/
*.pyc

# a11y tooling (dev-only; devDependencies in package.json)
node_modules/
docs/contribute-redesign/12-a11y-raw/

# visual regression tooling — baseline is committed, current/diff are
# per-run artefacts regenerated by `npm run visual`
tests/visual/current/
tests/visual/diff/

# Plain-text dump of the public site (regenerated by
# scripts/dump_site_text.py for offline evaluation / pasting into
# external review docs). Kept out of git because it changes on every
# copy edit and would balloon diffs.
/site-text.txt
