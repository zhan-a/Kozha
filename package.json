{
  "name": "kozha-a11y-tooling",
  "private": true,
  "version": "0.0.0",
  "description": "A11y tooling for the Bridgn/Kozha contribution flow. Dev-only; the site itself ships no Node dependencies.",
  "type": "module",
  "scripts": {
    "a11y": "node scripts/a11y/run.mjs",
    "a11y:ci": "node scripts/a11y/run.mjs --ci",
    "a11y:deploy-gate": "node scripts/a11y/run.mjs --critical-only",
    "visual": "node tests/visual/regression.mjs",
    "visual:baseline": "node tests/visual/regression.mjs --baseline"
  },
  "devDependencies": {
    "@axe-core/puppeteer": "^4.10.1",
    "@playwright/test": "^1.59.1",
    "axe-core": "^4.10.2",
    "pa11y": "^8.0.0",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "puppeteer": "^23.10.4"
  }
}
