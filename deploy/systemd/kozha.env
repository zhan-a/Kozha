# /etc/kozha.env — environment file for kozha.service.
#
# Permissions: `sudo chmod 600 /etc/kozha.env && sudo chown root:kozha /etc/kozha.env`.
# Never commit a populated copy of this file. Real secrets belong in
# the host's secret manager (e.g. systemd-creds, AWS SSM, HashiCorp Vault).

OPENAI_API_KEY=
# Gladia API key — backs /api/transcribe (server-side ASR fallback for
# the in-browser Whisper pipeline). Optional: when blank, the route
# returns 503 and the client surfaces the local Whisper error.
TRANSCRIBE_KEY=
CHAT2HAMNOSYS_SIGNER_ID_SALT=

CHAT2HAMNOSYS_DATA_DIR=/var/lib/kozha
CHAT2HAMNOSYS_LOG_DIR=/var/log/kozha
CHAT2HAMNOSYS_SESSION_DB=/var/lib/kozha/chat2hamnosys/sessions.sqlite3
CHAT2HAMNOSYS_SIGN_DB=/var/lib/kozha/authored_signs.sqlite3
CHAT2HAMNOSYS_TOKEN_DB=/var/lib/kozha/chat2hamnosys/session_tokens.sqlite3
CHAT2HAMNOSYS_REVIEWER_DB=/var/lib/kozha/chat2hamnosys/reviewers.sqlite3
CHAT2HAMNOSYS_EXPORT_AUDIT=/var/lib/kozha/chat2hamnosys/export_audit.jsonl

CHAT2HAMNOSYS_LOG_LEVEL=INFO
CHAT2HAMNOSYS_LOG_CONTENT=false
CHAT2HAMNOSYS_LOG_SINK=file
CHAT2HAMNOSYS_LOG_RETENTION_DAYS=30

CHAT2HAMNOSYS_CORS_ORIGINS=https://kozha.example
CHAT2HAMNOSYS_RATE_LIMIT=30/minute
CHAT2HAMNOSYS_RATE_LIMIT_PER_MIN=30

CHAT2HAMNOSYS_SESSION_BUDGET_USD=2.0
CHAT2HAMNOSYS_DAILY_BUDGET_USD=200.0
CHAT2HAMNOSYS_PER_IP_DAILY_CAP_USD=10.0
CHAT2HAMNOSYS_GLOBAL_DAILY_CAP_USD=200.0

CHAT2HAMNOSYS_REVIEW_MIN_APPROVALS=2
CHAT2HAMNOSYS_REVIEW_REQUIRE_NATIVE=true
CHAT2HAMNOSYS_REVIEW_ALLOW_SINGLE=false

CHAT2HAMNOSYS_PII_POLICY=hashed
CHAT2HAMNOSYS_ENABLE_INJECTION_CLASSIFIER=1
CHAT2HAMNOSYS_ENABLE_OUTPUT_MODERATION=1

BUILD_SHA=
