# ----------------------------------------------------------------------
# Kozha + chat2hamnosys environment template.
#
# Copy to `.env` (which is gitignored), fill in values, and `docker
# compose up`. Every variable below is documented in
# `docs/chat2hamnosys/19-env-vars.md` — if you need to add a new one,
# update both files in the same change.
#
# This file MUST NOT contain real secrets. CI's gitleaks job rejects
# anything that looks like a key (.gitleaks.toml).
# ----------------------------------------------------------------------

# -- Identity / build --------------------------------------------------
BUILD_SHA=dev                              # auto-overridden in CI; surfaced via /health
KOZHA_HTTP_PORT=8000                       # host port `backend` binds to
PROMETHEUS_HTTP_PORT=9090                  # only used with `--profile obs`

# -- LLM / OpenAI ------------------------------------------------------
OPENAI_API_KEY=                            # REQUIRED. sk-... — never commit a real key.

# -- Budget / cost guardrails -----------------------------------------
CHAT2HAMNOSYS_SESSION_BUDGET_USD=2.0       # per-session worst-case cap
CHAT2HAMNOSYS_DAILY_BUDGET_USD=200.0       # alert + projection ceiling
CHAT2HAMNOSYS_PER_IP_DAILY_CAP_USD=10.0    # per-IP throttle
CHAT2HAMNOSYS_GLOBAL_DAILY_CAP_USD=200.0   # process-wide hard ceiling

# -- Storage backend --------------------------------------------------
# Today the canonical store is SQLite (api/dependencies.py). The
# json-file backend is documented for future use; setting it has no
# effect until SignStore gains a json-file driver.
CHAT2HAMNOSYS_STORAGE_BACKEND=sqlite       # sqlite | json
CHAT2HAMNOSYS_STORAGE_PATH=/app/data/authored_signs.sqlite3

CHAT2HAMNOSYS_DATA_DIR=/app/data
CHAT2HAMNOSYS_SESSION_DB=/app/data/chat2hamnosys/sessions.sqlite3
CHAT2HAMNOSYS_SIGN_DB=/app/data/authored_signs.sqlite3
CHAT2HAMNOSYS_TOKEN_DB=/app/data/chat2hamnosys/session_tokens.sqlite3
CHAT2HAMNOSYS_REVIEWER_DB=/app/data/chat2hamnosys/reviewers.sqlite3
CHAT2HAMNOSYS_EXPORT_AUDIT=/app/data/chat2hamnosys/export_audit.jsonl

# -- HTTP surface -----------------------------------------------------
CHAT2HAMNOSYS_CORS_ORIGINS=*               # "*" for dev; comma-separated origins in prod
CHAT2HAMNOSYS_RATE_LIMIT=30/minute         # slowapi-format string
CHAT2HAMNOSYS_RATE_LIMIT_PER_MIN=30        # plain integer alias (see 19-env-vars.md)
CHAT2HAMNOSYS_MAX_INPUT_LEN=2000

# -- Logging / observability ------------------------------------------
CHAT2HAMNOSYS_LOG_LEVEL=INFO               # DEBUG / INFO / WARNING / ERROR
CHAT2HAMNOSYS_LOG_CONTENT=false            # if true, prose + answers are logged verbatim
CHAT2HAMNOSYS_LOG_SINK=file                # file | stdout
CHAT2HAMNOSYS_LOG_DIR=/app/logs
CHAT2HAMNOSYS_LOG_RETENTION_DAYS=30
CHAT2HAMNOSYS_ALERT_WEBHOOK_URL=           # optional Slack/Discord webhook
CHAT2HAMNOSYS_ALERT_INTERVAL_S=300
CHAT2HAMNOSYS_ALERT_SILENCE_S=1800
CHAT2HAMNOSYS_PENDING_REVIEW_STALE_H=24
CHAT2HAMNOSYS_ANOMALY_ALERT_URL=

# -- Renderer integration ---------------------------------------------
# CHAT2HAMNOSYS_RENDERER_URL is the documented HTTP endpoint a future
# renderer service exposes (see 19-env-vars.md). KOZHA_RENDERER_CMD is
# the legacy subprocess template (rendering/preview.py) and stays the
# default until the URL form is wired in.
CHAT2HAMNOSYS_RENDERER_URL=
KOZHA_RENDERER_CMD=

# -- Reviewer / governance --------------------------------------------
CHAT2HAMNOSYS_REVIEWER_APPROVAL_COUNT=2    # documented public name
CHAT2HAMNOSYS_REVIEW_MIN_APPROVALS=2       # canonical name read by review/policy.py
CHAT2HAMNOSYS_REVIEW_REQUIRE_NATIVE=true
CHAT2HAMNOSYS_REVIEW_ALLOW_SINGLE=false
CHAT2HAMNOSYS_REVIEW_FATIGUE_THRESHOLD=25
CHAT2HAMNOSYS_REVIEW_REQUIRE_REGION_MATCH=true

# -- Security ---------------------------------------------------------
CHAT2HAMNOSYS_PII_POLICY=hashed            # hashed | plaintext (plaintext requires IRB)
CHAT2HAMNOSYS_SIGNER_ID_SALT=              # set per-deployment; warn-on-default at boot
CHAT2HAMNOSYS_ENABLE_INJECTION_CLASSIFIER=1
CHAT2HAMNOSYS_ENABLE_OUTPUT_MODERATION=1
